{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      matchDatasources: [
        "docker",
        "github-tags"
      ],
      automerge: true,
      automergeType: "branch",
      ignoreTests: true,
      platformCommit: true,
      matchUpdateTypes: [
        "minor",
        "patch",
      ]
    }
  ]
}
