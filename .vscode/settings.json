{
    "workbench.colorTheme": "Night Owl",
    "workbench.tips.enabled": false,
    "workbench.statusBar.visible": true,
    "sops.beta": true,
    "sops.binPath": "$HOME/opt/homebrew/bin/sops",
    "sops.configPath": ".sops.yaml",
    "sops.defaults.ageKeyFile": "$SOPS_AGE_KEY_FILE",
    "sops-edit.onlyUseButtons": true,
    "python.analysis.addImport.exactMatchOnly": true,
    "autoDocstring.docstringFormat": "pep257",
    "autoDocstring.startOnNewLine": true,
    "files.associations": {
      "*.yaml": "yaml"
    },
    // "files.associations": {
    //   "*.yaml": "home-assistant"
    // }
}
