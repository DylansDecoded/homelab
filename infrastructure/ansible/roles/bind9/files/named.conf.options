
acl “trusted” {
 10.1.1.0/24;
 10.1.10.0/24;
 10.1.20.0/24;
 10.1.30.0/24;
 10.1.33.0/24;
 10.1.40.0/24;
};

acl "dmz-dns" {
  10.1.100.51;
  10.1.100.52;
}

options {
 directory “/var/cache/bind”;
 allow-transfer { none; };

 allow-query { trusted; };
 listen-on port 53 { localhost; 10.1.100.51; };
 recursion no;
 dnssec-validation auto;
};
