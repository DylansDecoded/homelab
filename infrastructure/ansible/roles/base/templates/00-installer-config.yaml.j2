network:
  version: 2
  renderer: networkd
  ethernets:
    mainif:
      match:
        macaddress: {{ ansible_default_ipv4.macaddress }}
      set-name: mainif
      dhcp4: no
      dhcp6: no
      addresses:
        - {{ ansible_default_ipv4.address }}/24
      nameservers:
        addresses: [10.1.100.51]
        search: [.]
      routes:
        - to: default
          via: 10.1.33.1

  vlans:
    vlan20:
      id: 20
      link: mainif
      addresses:
        - {{ vpn_address }}/24
      nameservers:
        addresses: [10.1.100.51]
        search: [.]
    vlan101:
      id: 101
      link: mainif
      addresses:
        - {{ storage_address }}/24

