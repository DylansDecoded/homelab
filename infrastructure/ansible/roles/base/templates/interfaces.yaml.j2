source /etc/network/interfaces.d/*

# The loopback network interface
auto lo
iface lo inet loopback

# The primary network interface
allow-hotplug {{ ansible_default_ipv4.interface }}
auto {{ ansible_default_ipv4.interface }}
iface {{ ansible_default_ipv4.interface }} inet static
        address {{ansible_default_ipv4.address }}/24
        gateway 10.1.30.1
        dns-nameservers 10.1.100.53
        mtu 9000

auto {{ ansible_default_ipv4.interface }}.20
iface {{ ansible_default_ipv4.interface }}.20 inet static
        address {{ vpn_network_address }}/24
        vlan-raw-device {{ ansible_default_ipv4.interface }}
        mtu 9000

auto {{ ansible_default_ipv4.interface }}.101
iface {{ ansible_default_ipv4.interface }}.101 inet static
        address {{ storage_network_address }}/24
        vlan-raw-device {{ ansible_default_ipv4.interface }}
        mtu 9000
