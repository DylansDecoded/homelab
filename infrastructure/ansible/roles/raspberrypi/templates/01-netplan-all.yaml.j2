network:
  version: 2
  renderer: networkd
  ethernets:
    mainif:
      match:
        macaddress: {{ ansible_default_ipv4.macaddress }}
      set-name: mainif
      dhcp4: no
      dhcp6: no
      addresses:
        - {{ ansible_default_ipv4.address }}/24
      nameservers:
        addresses: [ {{ dns_servers | join(', ')}}]
        search: [.]
      routes:
        - to: default
          via: {{ ansible_default_ipv4.gateway }}

  vlans:
    vlan33:
      id: 33
      link: mainif
      addresses: [ {{container_network_address }}/24 ]
    vlan100:
      id: 100
      link: mainif
      addresses: [ {{ dmz_network_address }}/24 ]
    vlan101:
      id: 101
      link: mainif
      addresses: [ {{ storage_network_address }}/24 ]

