---
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: cilium
  namespace: kube-system
spec:
  repo: https://helm.cilium.io/
  chart: cilium
  # renovate: datasource=helm depName=cilium repository=https://helm.cilium.io
  version: 1.15.3
  targetNamespace: kube-system
  bootstrap: true
  valuesContent: |-
    cluster:
    name: main
    id: 1

    cni:
      exclusive: false

    bgp:
      enabled: false
      announce:
        loadbalancerIP: true
        podCIDR: false

    bgpControlPlane:
      enabled: true

    bandwidthManager:
      enabled: true
      bbr: true

    bpf:
      masquerade: true
      tproxy: true

    cgroup:
      automount:
        enabled: false
      hostRoot: /sys/fs/cgroup

    autoDirectNodeRoutes: true
    ipv4NativeRoutingCIDR: 10.42.0.0/16
    routingMode: native
    containerRuntime:
      integration: containerd

    ipam:
      mode: kubernetes

    hubble:
      enabled: true
      serviceMonitor:
        enabled: false

    ipv4NativeRoutingCIDR: "{{ k3s_server['cluster-cidr'] }}"
    k8sServiceHost: 127.0.0.1
    k8sServicePort: 7445
    kubeProxyReplacement: true
    kubeProxyReplacementHealthzBindAddr: 0.0.0.0:10256
    loadBalancer:
      algorithm: maglev
      mode: dsr
    l7Proxy: true
    localRedirectPolicy: true
    operator:
      rollOutPods: true
    rollOutCiliumPods: true
    routingMode: native
    securityContext:
      capabilities:
        ciliumAgent:
          - CHOWN
          - KILL
          - NET_ADMIN
          - NET_RAW
          - IPC_LOCK
          - SYS_ADMIN
          - SYS_RESOURCE
          - DAC_OVERRIDE
          - FOWNER
          - SETGID
          - SETUID
        cleanCiliumState:
          - NET_ADMIN
          - SYS_ADMIN
          - SYS_RESOURCE
